TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_CHANNEL_ID=

# Required: this bot works only with Local Bot API.
# Examples:
# - Bot running on host: http://localhost:8081
# - App container in this repo's docker-compose: http://botapi:8081
BOT_API_ROOT=http://localhost:8081

# Required for Local Bot API server itself (docker and non-docker modes)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional upload tuning on top of Local Bot API defaults (2000 MB, 0.95 safety ratio)
TELEGRAM_UPLOAD_LIMIT_MB=
TELEGRAM_UPLOAD_SAFETY_RATIO=

BOT_API_RETRY_MAX_ATTEMPTS=4
BOT_API_MAX_CONCURRENT=8
BOT_RATE_LIMIT_WINDOW_MS=60000
BOT_RATE_LIMIT_REQUESTS=5
