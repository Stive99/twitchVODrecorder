{
	"name": "twitchvodrecorder",
	"version": "0.4.0",
	"module": "src/bot.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --watch src/bot.ts",
		"start": "bun src/bot.ts",
		"lint": "eslint . --ext .ts,.mts,.cts,.js,.mjs,.cjs --max-warnings 0",
		"lint:fix": "eslint . --ext .ts,.mts,.cts,.js,.mjs,.cjs --fix",
		"botapi:docker:up": "docker compose --profile botapi up -d botapi",
		"botapi:docker:up:all": "docker compose --profile botapi up -d --build",
		"botapi:docker:down": "docker compose --profile botapi down",
		"botapi:docker:logs": "docker compose --profile botapi logs -f botapi",
		"botapi:local:ps1": "powershell -NoProfile -ExecutionPolicy Bypass -File ./start-local-bot-api.ps1",
		"botapi:local:sh": "bash ./start-local-bot-api.sh"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "1.3.9",
		"eslint": "^10.0.1",
		"typescript-eslint": "^8.56.0"
	},
	"dependencies": {
		"@grammyjs/auto-retry": "^2.0.2",
		"@grammyjs/ratelimiter": "^1.2.1",
		"@grammyjs/runner": "^2.0.3",
		"@grammyjs/transformer-throttler": "^1.2.1",
		"dotenv": "^17.3.1",
		"grammy": "^1.40.1"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}