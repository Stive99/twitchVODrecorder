{
	"name": "twitchvodrecorder",
	"version": "0.5.0",
	"module": "src/bot.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun --watch src/bot.ts",
		"start": "bun src/bot.ts",
		"lint": "eslint . --ext .ts,.mts,.cts,.js,.mjs,.cjs --max-warnings 0",
		"lint:fix": "eslint . --ext .ts,.mts,.cts,.js,.mjs,.cjs --fix",
		"docker:up": "docker compose up -d botapi",
		"docker:up:all": "docker compose up -d --build",
		"docker:stop": "docker compose stop botapi",
		"docker:stop:all": "docker compose stop",
		"docker:logs": "docker compose logs -f botapi",
		"docker:logs:app": "docker compose logs -f app",
		"docker:logs:all": "docker compose logs -f",
		"docker:down": "docker compose down"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/bun": "^1.3.11",
		"eslint": "^10.1.0",
		"typescript-eslint": "^8.57.2"
	},
	"dependencies": {
		"@grammyjs/auto-retry": "^2.0.2",
		"@grammyjs/ratelimiter": "^1.2.1",
		"@grammyjs/runner": "^2.0.3",
		"@grammyjs/transformer-throttler": "^1.2.1",
		"dotenv": "^17.3.1",
		"grammy": "^1.41.1"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	}
}