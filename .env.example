TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=
TELEGRAM_CHANNEL_ID=

# Optional local Bot API endpoint (examples):
# - Docker botapi from this repo: http://localhost:8081
# - Same docker-compose network from app container: http://botapi:8081
BOT_API_ROOT=
BOT_API_LOCAL_BIN=

# Required for Local Bot API server itself (docker and non-docker modes)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional upload tuning (auto defaults depend on BOT_API_ROOT mode)
TELEGRAM_UPLOAD_LIMIT_MB=
TELEGRAM_UPLOAD_SAFETY_RATIO=

BOT_API_RETRY_MAX_ATTEMPTS=4
BOT_API_MAX_CONCURRENT=8
BOT_RATE_LIMIT_WINDOW_MS=60000
BOT_RATE_LIMIT_REQUESTS=5
